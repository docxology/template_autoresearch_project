# AutoResearch exemplar configuration template
# Copy to config.yaml and customize. See docs/guides/zenodo-doi-strategy.md for split DOI layout.

paper:
  title: "Your AutoResearch Title"
  subtitle: "Optional subtitle"
  version: "0.1.0"

authors:
  - name: "Your Name"
    orcid: "0000-0000-0000-0000"
    email: "your.email@example.com"
    affiliation: "Your Institution"
    corresponding: true

publication:
  doi: ""  # Concept DOI — stable citation; PDF cover and CITATION.cff
  version_doi: ""  # Latest Zenodo version DOI
  version_record: ""  # https://zenodo.org/records/{id}
  github_repository: ""  # e.g. docxology/template_autoresearch_project
  transmission_bookends:
    enabled: false
    max_prior_releases: 5
    show_steganography: true

keywords:
  - "autoresearch"
  - "reproducible research"

metadata:
  license: "MIT"
  language: "en"

render:
  formats:
    pdf: true
    html: true
    slides: true
    docx: false
    epub: false

analysis:
  scripts:
    - run_autoresearch_loop.py
    - z_generate_manuscript_variables.py

project_config:
  review_policy: "human_review_required"
  loop_stages:
    - plan
    - gate
    - experiment
    - evidence
    - claims
    - artifacts
    - readiness
  research_questions:
    - id: "rq1"
      question: "What bounded offline research question should this fork answer?"
      expected_evidence: "output/reports/autoresearch_loop.md"
